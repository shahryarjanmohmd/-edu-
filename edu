void forgot_password() {
    char username[50];
    get_input("Enter your username: ", username, 50);
    
    Student* s = find_student_by_username(username);
    if (!s) {
        printf("Username not found.\n");
        printf("1. Retry\n2. Go to login menu\n");
        int choice = get_int("Enter an option: ");
        if (choice == 1) {
            forgot_password();
        }
        return;
    }
    
    char answer[100];
    int question = 0;
    int retry = 0;
    
    while (question < 3) {
        if (question == 0) {
            printf("Where were you born? ");
        } else if (question == 1) {
            printf("What was the title of the first book you read? ");
        } else {
            printf("What was the color of your first bicycle? ");
        }
        
        get_input("", answer, 100);
        
        int correct = 0;
        if (question == 0 && strcmp(answer, s->birthplace) == 0) correct = 1;
        else if (question == 1 && strcmp(answer, s->first_book) == 0) correct = 1;
        else if (question == 2 && strcmp(answer, s->first_bicycle_color) == 0) correct = 1;
        
        if (correct) {
            question++;
            retry = 0;
        } else {
            printf("Incorrect answer.\n");
            retry++;
            if (retry >= 3) {
                printf("Too many incorrect attempts.\n");
                return;
            }
            printf("1. Retry\n2. Go to login menu\n");
            int choice = get_int("Enter an option: ");
            if (choice == 2) {
                return;
            }
        }
    }
    
    printf("Authentication successful.\n");
    char new_pass[50], confirm[50];
    
    while (1) {
        get_input("Enter your new password: ", new_pass, 50);
        get_input("Confirm your password: ", confirm, 50);
        
        if (strcmp(new_pass, confirm) == 0) {
            break;
        } else {
            printf("Passwords aren't matching.\n");
            printf("1. Retry\n2. Cancel (go to login menu)\n");
            int choice = get_int("Enter an option: ");
            if (choice == 2) {
                return;
            }
        }
    }
    
    strcpy(s->password, new_pass);
    save_students();
    printf("Password changed successfully.\n");
    wait_for_key();
}

void login() {
    int option;
    do {
        print_header();
        printf("1. Login as student\n");
        printf("2. Login as faculty\n");
        printf("3. Login as admin\n");
        printf("4. Forgot password\n");
        printf("5. Exit\n");
        printf("\nEnter an option: ");
        option = get_int("");
        
        if (option == 1 || option == 2 || option == 3) {
            char username[50], password[50];
            get_input("Enter your username: ", username, 50);
            
            if (option == 3) {
                if (strcmp(username, "admin") == 0) {
                    get_input("Enter password: ", password, 50);
                    if (strcmp(password, "admin123") == 0) {
                        admin_menu();
                    } else {
                        printf("Invalid password.\n");
                    }
                } else {
                    printf("Invalid admin username.\n");
                }
                continue;
            }
            
            if (option == 1) {
                Student* s = find_student_by_username(username);
                if (!s) {
                    printf("Username not found.\n");
                    continue;
                }
                get_input("Enter password: ", password, 50);
                if (strcmp(s->password, password) == 0) {
                    student_menu(s);
                } else {
                    printf("Incorrect password.\n");
                }
            } else if (option == 2) {
                Faculty* f = find_faculty_by_username(username);
                if (!f) {
                    printf("Username not found.\n");
                    continue;
                }
                get_input("Enter password: ", password, 50);
                if (strcmp(f->password, password) == 0) {
                    faculty_menu(f);
                } else {
                    printf("Incorrect password.\n");
                }
            }
        } else if (option == 4) {
            forgot_password();
        } else if (option == 5) {
            printf("Goodbye!\n");
            break;
        } else {
            printf("Invalid option.\n");
        }
    } while(1);
}

