    sprintf(off.offering_id, "O%d", offering_count + 1);
    strcpy(off.course_id, course_id);
    strcpy(off.faculty_id, faculty->faculty_id);
    strcpy(off.semester, semester);
    off.capacity = capacity;
    off.enrolled_count = 0;
    strcpy(off.location, "Room 201, Science Building");
    strcpy(off.status, "pending");
    
    offerings[offering_count++] = off;
    save_offerings();
    
    printf("Sent request to admin. Waiting for approval.\n");
    printf("Offering ID: %s\n", off.offering_id);
    wait_for_key();
}

void faculty_my_offerings(Faculty* faculty) {
    char semester[10];
    get_input("Enter semester number (or 'all' for all): ", semester, 10);
    
    load_offerings();
    load_courses();
    load_students();
    
    // Store offering IDs for lookup
    char offering_ids[100][10];
    int id_count = 0;
    
    printf("\nMy offerings for semester %s:\n", semester);
    printf("| %-6s | %-8s | %-30s | %-10s | %-8s | %-10s | %-10s |\n", 
        "Number", "Off ID", "Course Name", "Course ID", "Capacity", "Enrolled", "Status");
    printf("-----------------------------------------------------------------------------------------------------\n");
    
    for (int i = 0; i < offering_count; i++) {
        if (strcmp(offerings[i].faculty_id, faculty->faculty_id) == 0) {
            if (strcmp(semester, "all") == 0 || strcmp(offerings[i].semester, semester) == 0) {
                Course* c = find_course(offerings[i].course_id);
                printf("| %-6d | %-8s | %-30s | %-10s | %-8d | %-10d | %-10s |\n",
                    id_count + 1,
                    offerings[i].offering_id,
                    c ? c->course_name : "Unknown",
                    c ? c->course_id : "Unknown",
                    offerings[i].capacity,
                    offerings[i].enrolled_count,
                    offerings[i].status);
                
                strcpy(offering_ids[id_count], offerings[i].offering_id);
                id_count++;
            }
        }
    }
    
    if (id_count == 0) {
        printf("No offerings found.\n");
        wait_for_key();
        return;
    }
    
    int choice = get_int("\n1. Go to offering\n2. Go back\nEnter an option: ");
    
    if (choice == 1) {
        int num = get_int("Enter offering number (1-%d): ", id_count);
        
        if (num < 1 || num > id_count) {
            printf("Invalid number.\n");
            wait_for_key();
            return;
        }
        
        char* oid = offering_ids[num - 1];
        Offering* off = find_offering(oid);
        
        if (!off || strcmp(off->faculty_id, faculty->faculty_id) != 0) {
            printf("Invalid offering.\n");
            wait_for_key();
            return;
        }
        
        printf("\n=== Offering Details ===\n");
        printf("Offering ID: %s\n", off->offering_id);
        printf("Course ID: %s\n", off->course_id);
        Course* c = find_course(off->course_id);
        printf("Course Name: %s\n", c ? c->course_name : "Unknown");
        printf("Semester: %s\n", off->semester);
        printf("Capacity: %d, Enrolled: %d\n", off->capacity, off->enrolled_count);
        printf("Status: %s\n", off->status);
        
        printf("\n1. Add capacity\n");
        printf("2. Record grades\n");
        printf("3. Remove offering (request)\n");
        printf("4. Go back\n");
        int sub = get_int("Enter an option: ");
        
        if (sub == 1) {
            if (strcmp(off->status, "approved") != 0) {
                printf("Offering is not approved yet.\n");
                wait_for_key();
                return;
            }
            int extra = get_int("Enter extra capacity: ");
            off->capacity += extra;
            save_offerings();
            printf("Capacity increased to %d.\n", off->capacity);
            wait_for_key();
        }
        else if (sub == 2) {
            if (!is_grade_recording_time()) {
                printf("Grade recording is not active!\n");
                wait_for_key();
                return;
            }
            
            if (strcmp(off->status, "approved") != 0) {
                printf("Offering is not approved yet.\n");
                wait_for_key();
                return;
            }
            
            load_students();
            printf("\nRecording grades for offering %s\n", off->offering_id);
            printf("Number of students enrolled: %d\n", off->enrolled_count);
            
            for (int i = 0; i < off->enrolled_count; i++) {
                Student* s = find_student_by_id(off->student_ids[i]);
                if (s) {
                    printf("Student: %s %s (%s)\n", s->first_name, s->last_name, s->student_id);
                    float grade = (float)get_int("Enter grade (0-20): ");
                    off->grades[i] = grade;
                    
                    for (int j = 0; j < s->enrollment_count; j++) {
                        if (strcmp(s->enrollments[j].offering_id, off->offering_id) == 0) {
                            s->enrollments[j].grade = grade;
                            break;
                        }
                    }
                }
            }
            save_students();
            save_offerings();
            printf("Grades recorded.\n");
            wait_for_key();
        }
        else if (sub == 3) {
            if (is_offering_time()) {
                strcpy(off->status, "pending_removal");
                save_offerings();
                printf("Removal request sent to admin for approval.\n");
            } else {
                printf("Cannot remove offering outside offering period.\n");
            }
            wait_for_key();
        }
    }
}

void faculty_menu(Faculty* faculty) {
    int option;
    do {
        print_header();
        printf("Welcome %s %s\n", faculty->title, faculty->last_name);
        printf("1. My offerings\n");
        printf("2. Offer a course\n");
        printf("3. Log out\n");
        printf("\nEnter an option: ");
        option = get_int("");
        
        switch(option) {
            case 1: faculty_my_offerings(faculty); break;
            case 2: faculty_offer_course(faculty); break;
            case 3: printf("Logging out...\n"); return;
            default: printf("Invalid option.\n");
        }
    } while(1);
}

