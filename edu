// ================ CALENDAR FUNCTIONS ================

void print_calendar() {
    printf("\n1. offering: %s\n", calendar.offering_enabled ? "enabled" : "disabled");
    printf("2. unit selection: %s\n", calendar.unit_selection_enabled ? "enabled" : "disabled");
    printf("3. class & exams: %s\n", calendar.class_exam_enabled ? "enabled" : "disabled");
    printf("4. grade recording: %s\n", calendar.grade_recording_enabled ? "enabled" : "disabled");
}

void trigger_time(int phase) {
    if (phase == 1) {
        if (calendar.unit_selection_enabled || calendar.class_exam_enabled || calendar.grade_recording_enabled) {
            printf("Cannot enable offering while later phases are active!\n");
            return;
        }
        calendar.offering_enabled = !calendar.offering_enabled;
        if (calendar.offering_enabled) {
            calendar.unit_selection_enabled = 0;
            calendar.class_exam_enabled = 0;
            calendar.grade_recording_enabled = 0;
            calendar.current_phase = 0;
        }
    } else if (phase == 2) {
        if (!calendar.offering_enabled && !calendar.unit_selection_enabled) {
            printf("Cannot enable unit selection before offering!\n");
            return;
        }
        if (calendar.class_exam_enabled || calendar.grade_recording_enabled) {
            printf("Cannot enable unit selection while later phases are active!\n");
            return;
        }
        calendar.unit_selection_enabled = !calendar.unit_selection_enabled;
        if (calendar.unit_selection_enabled) {
            calendar.class_exam_enabled = 0;
            calendar.grade_recording_enabled = 0;
            calendar.current_phase = 1;
        }
    } else if (phase == 3) {
        if (!calendar.unit_selection_enabled && !calendar.class_exam_enabled) {
            printf("Cannot enable class/exam before unit selection!\n");
            return;
        }
        if (calendar.grade_recording_enabled) {
            printf("Cannot enable class/exam while grade recording is active!\n");
            return;
        }
        calendar.class_exam_enabled = !calendar.class_exam_enabled;
        if (calendar.class_exam_enabled) {
            calendar.grade_recording_enabled = 0;
            calendar.current_phase = 2;
        }
    } else if (phase == 4) {
        if (!calendar.class_exam_enabled && !calendar.grade_recording_enabled) {
            printf("Cannot enable grade recording before class/exam!\n");
            return;
        }
        calendar.grade_recording_enabled = !calendar.grade_recording_enabled;
        if (calendar.grade_recording_enabled) {
            calendar.current_phase = 3;
        }
    }
    printf("Phase toggled.\n");
}

int is_offering_time() { return calendar.offering_enabled; }
int is_unit_selection_time() { return calendar.unit_selection_enabled; }
int is_class_exam_time() { return calendar.class_exam_enabled; }
int is_grade_recording_time() { return calendar.grade_recording_enabled; }

